generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Task Enums ───────────────────────────────────────────

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  STUCK
  AWAITING_RESPONSE
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  FORTNIGHTLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ScheduleType {
  FIXED
  FLOATING
}

// ─── Task (Quick Tasks) ──────────────────────────────────

model Task {
  id         String       @id @default(uuid())
  title      String
  projectId  String?
  notes      String?
  label      String       @default("Task")
  dueDate    DateTime?
  status     TaskStatus   @default(NOT_STARTED)
  priority   TaskPriority @default(LOW)

  // Generic assignee — the consuming app resolves this to its own user/employee
  assigneeId   String
  // Who created/archived — consuming app maps to its own User model
  createdById  String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?

  // Multi-tenant: which app owns this task (e.g. "acoms", "wip")
  appId        String   @default("default")

  @@index([status])
  @@index([dueDate])
  @@index([assigneeId])
  @@index([appId])
}

// ─── Recurring Task ──────────────────────────────────────

model RecurringTask {
  id              String             @id @default(uuid())
  title           String
  description     String?
  category        String             @default("Task")
  frequencyType   RecurringFrequency @default(WEEKLY)
  frequencyValue  Int                @default(1)
  scheduleType    ScheduleType       @default(FLOATING)
  lastCompleted   DateTime?
  nextDue         DateTime?

  assigneeId   String
  createdById  String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  isArchived   Boolean  @default(false)
  archivedAt   DateTime?
  archivedById String?

  appId        String   @default("default")

  @@index([nextDue])
  @@index([assigneeId])
  @@index([appId])
}

// ─── Quick Note ─────────────────────────────────────────

model QuickNote {
  id      String @id @default(uuid())
  content String @default("")

  // Owner — each user only sees their own notes
  createdById String

  // When converted to a task, stores the task ID (also acts as "converted" flag)
  convertedToTaskId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isPinned Boolean  @default(false)
  pinnedAt DateTime?

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?

  appId String @default("default")

  @@index([createdById])
  @@index([isArchived])
  @@index([appId])
  @@index([isPinned])
}

// ─── Diary ──────────────────────────────────────────────

enum DiaryEntryType {
  NOTE
  EVENT
  CONVERSATION
}

model DiaryEntry {
  id      String         @id @default(uuid())
  type    DiaryEntryType @default(NOTE)
  date    DateTime                            // user-editable, defaults to today
  heading String
  people  String[]       @default([])         // tag-style array of names
  content String         @default("")         // free-text body

  isImportant Boolean @default(false)         // red dot toggle

  // Owner — each user only sees their own entries
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?

  appId String @default("default")

  @@index([createdById])
  @@index([date])
  @@index([type])
  @@index([isArchived])
  @@index([appId])
}

// ─── Audit Log ───────────────────────────────────────────

model AuditLog {
  id            String   @id @default(uuid())
  entityType    String
  entityId      String
  action        String
  entityLabel   String
  changes       Json?
  performedById String
  performedAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedAt])
}

// ═════════════════════════════════════════════════════════
// MATERIAL TRACKER
// ═════════════════════════════════════════════════════════

// ─── Material Enums ─────────────────────────────────────

enum MovementType {
  RECEIVED
  RECEIVED_FREE_ISSUE
  ISSUED
  TRANSFERRED
  RETURNED_FROM_JOB
  RETURNED_TO_SUPPLIER
  ADJUSTED
}

enum OwnershipType {
  COMPANY
  CLIENT_FREE_ISSUE
}

enum UnitOfMeasure {
  EACH
  METRE
  ROLL
  KILOGRAM
  LITRE
  BOX
  PACK
  LENGTH
  SET
  OTHER
}

enum SourceType {
  SUPPLIER
  CLIENT
  INTERNAL
}

enum JobMaterialStatus {
  PENDING
  REQUESTED
  FULFILLED
}

enum StocktakeStatus {
  DRAFT
  COMPLETED
}

enum ClientReturnStatus {
  TO_BE_RETURNED
  RETURNED
}

// ─── Supplier ───────────────────────────────────────────

model Supplier {
  id          String  @id @default(cuid())
  name        String  @unique
  contactName String?
  phone       String?
  email       String?
  notes       String?

  // Free-issue flag — when true, all linked items are CLIENT_FREE_ISSUE
  isFreeIssue Boolean @default(false)
  clientName  String?

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  items Item[]

  @@index([isArchived])
}

// ─── Item (Master Item Register) ────────────────────────

model Item {
  id                  String        @id @default(cuid())
  code                String        @unique
  description         String
  category            String?
  unitOfMeasure       UnitOfMeasure @default(EACH)
  customUnitOfMeasure String?
  aliases             String[]      @default([])
  minimumStockLevel   Decimal?
  notes               String?

  // Ownership — company-purchased or client free issue
  ownershipType OwnershipType @default(COMPANY)
  clientName    String?

  // Supplier link
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?
  createdById  String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  movements      StockMovement[]
  stocktakeLines StocktakeLine[]
  pickListItems  PickListItem[]
  jobMaterials   JobMaterial[]
  clientReturns  ClientReturn[]

  @@index([code])
  @@index([category])
  @@index([isArchived])
  @@index([supplierId])
  @@index([ownershipType])
}

// ─── Job ────────────────────────────────────────────────

model Job {
  id        String @id @default(cuid())
  projectId String @unique                // WIP acomsNumber formatted (e.g. "A0023")
  name      String
  client    String
  contact   String

  // ── WIP integration ──
  wipProjectId String? @unique            // UUID from ACOMS.WIP projects table
  stage        String?                    // Current WIP stage (synced on load)
  siteAddress  String?                    // From WIP
  depotName    String?                    // WIP depot name (display only)
  wipSyncedAt  DateTime?                  // Last time data was refreshed from WIP

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  createdById String
  createdAt   DateTime @default(now())

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?

  movements     StockMovement[]
  materials     JobMaterial[]
  clientReturns ClientReturn[]

  @@index([isArchived])
  @@index([locationId])
  @@index([wipProjectId])
}

// ─── Job Material Requirements ──────────────────────────

model JobMaterial {
  id           String            @id @default(cuid())
  jobId        String
  itemId       String
  requiredQty  Decimal
  fromStockQty Decimal           @default(0)
  status       JobMaterialStatus @default(PENDING)
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job  Job  @relation(fields: [jobId], references: [id])
  item Item @relation(fields: [itemId], references: [id])

  @@unique([jobId, itemId])
  @@index([jobId])
}

// ─── Location ───────────────────────────────────────────

model Location {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  isArchived   Boolean   @default(false)
  archivedAt   DateTime?
  archivedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  movementsFrom StockMovement[] @relation("FromLocation")
  movementsTo   StockMovement[] @relation("ToLocation")
  stocktakes    Stocktake[]
  jobs          Job[]
  clientReturns ClientReturn[]

  @@index([isArchived])
}

// ─── Stock Movement (Core — immutable after creation) ───

model StockMovement {
  id            String        @id @default(cuid())
  itemId        String
  quantity      Decimal
  movementType  MovementType
  ownershipType OwnershipType @default(COMPANY)

  fromLocationId String?
  toLocationId   String?

  // Client tracking (future WIP integration ready)
  clientName       String?
  externalClientId String?

  // Project/Job tracking (future WIP integration ready)
  projectName       String?
  projectCode       String?
  externalProjectId String?

  // External system mapping
  externalSource String?

  // Source context
  sourceType SourceType?
  sourceName String?

  // References
  reference             String?
  notes                 String?
  attachmentPlaceholder String?

  createdById String
  createdAt   DateTime @default(now())

  // Job link
  jobId String?

  // Relations
  item         Item      @relation(fields: [itemId], references: [id])
  fromLocation Location? @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location? @relation("ToLocation", fields: [toLocationId], references: [id])
  job          Job?      @relation(fields: [jobId], references: [id])

  stocktakeLine StocktakeLine?

  @@index([itemId])
  @@index([movementType])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([clientName])
  @@index([projectCode])
  @@index([jobId])
  @@index([createdAt])
}

// ─── Client Returns ─────────────────────────────────────

model ClientReturn {
  id         String             @id @default(cuid())
  itemId     String
  quantity   Decimal
  jobId      String?
  locationId String
  status     ClientReturnStatus @default(TO_BE_RETURNED)
  notes      String?
  returnedAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  item     Item     @relation(fields: [itemId], references: [id])
  job      Job?     @relation(fields: [jobId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@index([status])
  @@index([jobId])
  @@index([locationId])
}

// ─── Stocktake ──────────────────────────────────────────

model Stocktake {
  id          String          @id @default(cuid())
  locationId  String
  status      StocktakeStatus @default(DRAFT)
  notes       String?
  completedAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location Location        @relation(fields: [locationId], references: [id])
  lines    StocktakeLine[]

  @@index([locationId])
  @@index([status])
}

model StocktakeLine {
  id          String  @id @default(cuid())
  stocktakeId String
  itemId      String
  expectedQty Decimal
  countedQty  Decimal @default(0)
  notes       String?

  // Links to the adjustment movement created on completion
  movementId String?        @unique
  movement   StockMovement? @relation(fields: [movementId], references: [id])

  stocktake Stocktake @relation(fields: [stocktakeId], references: [id])
  item      Item      @relation(fields: [itemId], references: [id])

  @@unique([stocktakeId, itemId])
  @@index([stocktakeId])
}

// ─── Pick List Templates ────────────────────────────────

model PickList {
  id          String @id @default(cuid())
  name        String @unique
  description String?

  isArchived  Boolean  @default(false)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PickListItem[]
}

model PickListItem {
  id         String  @id @default(cuid())
  pickListId String
  itemId     String
  defaultQty Decimal @default(1)

  pickList PickList @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])

  @@unique([pickListId, itemId])
  @@index([pickListId])
}
