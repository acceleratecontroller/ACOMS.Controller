# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/todo?sslmode=require"

# NextAuth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# ACOMS.Auth OIDC Configuration
ACOMS_AUTH_URL="https://acoms-auth.vercel.app"
ACOMS_AUTH_CLIENT_ID="acoms-controller"
ACOMS_AUTH_CLIENT_SECRET="your-client-secret-here"

# ACOMS.OS API (for employee data)
ACOMS_OS_API_URL="https://acoms-os.vercel.app"
ACOMS_OS_SERVICE_TOKEN="your-os-service-token-here"

# ACOMS.WIP API (for project/job data)
ACOMS_WIP_API_URL="https://acoms-wip.vercel.app"
ACOMS_WIP_SERVICE_TOKEN="your-wip-service-token-here"
